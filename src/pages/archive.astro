---
import ArchivePanel from "@components/ArchivePanel.svelte";
import I18nKey from "@i18n/i18nKey";
import { i18n } from "@i18n/translation";
import MainGridLayout from "@layouts/MainGridLayout.astro";
import { getSortedPostsList } from "../utils/content-utils";

const sortedPostsList = await getSortedPostsList();
---


<MainGridLayout title={i18n(I18nKey.archive)}>
    <ArchivePanel
        sortedPosts={sortedPostsList.map(post => ({
            ...post,
            data: {
                ...post.data,
                category: post.data.category || undefined
            }
        }))}
        tags={[...new Set(sortedPostsList.flatMap(post => post.data.tags))]}
        categories={[...new Set(sortedPostsList.map(post => post.data.category).filter((cat): cat is string => typeof cat === 'string'))]}
        client:only="svelte"
    />
    <!-- <ArchivePanel sortedPosts={sortedPostsList} client:only="svelte"></ArchivePanel> -->
</MainGridLayout>

